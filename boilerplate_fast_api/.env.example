# ==============================================================================
# 🚀 Configurações do Projeto (FastAPI Boilerplate)
# ==============================================================================
# Copie este arquivo para '.env' e ajuste conforme necessário.
# Não versionar o arquivo '.env' real!
# ==============================================================================

# --- Aplicação ---
PROJECT_NAME="FastAPI Boilerplate"
SECRET_KEY="SUA_CHAVE_SUPER_SECRETA_MUDE_EM_PRODUCAO"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Banco de Dados ---
# SQLITE (Padrão local): sqlite:///./app.db
# POSTGRES (Exemplo para Docker): postgresql://user:pass@host:port/dbname
# DATABASE_URL="postgresql://boilerplate_user:boilerplate_password@db:5432/boilerplate_app"

DATABASE_URL="sqlite:///./app.db"
